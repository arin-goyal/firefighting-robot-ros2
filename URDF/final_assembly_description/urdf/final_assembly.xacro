<?xml version="1.0" ?>
<robot name="final_assembly" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find final_assembly_description)/urdf/materials.xacro" />
<xacro:include filename="$(find final_assembly_description)/urdf/final_assembly.trans" />
<xacro:include filename="$(find final_assembly_description)/urdf/final_assembly.gazebo" />

<link name="base_footprint"/>
<joint name="base_footprint_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="dummy"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
</joint>

<link name="dummy"/>
<joint name="dummy_joint" type="fixed">
  <parent link="dummy"/>
  <child link="base_link"/>
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="3.4660443265257375e-07 0.02133699115978159 0.10448988049708854" rpy="0 0 0"/>
    <mass value="53.75875243208703"/>
    <inertia ixx="0.496438" iyy="0.443818" izz="0.674768" ixy="1e-06" iyz="-0.040611" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="wheel_1">
  <inertial>
    <origin xyz="0.019047494333213788 -4.163336342344337e-17 -2.7755575615628914e-17" rpy="0 0 0"/>
    <mass value="2.3329933490707657"/>
    <inertia ixx="0.002974" iyy="0.001772" izz="0.001772" ixy="0.0" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.15 -0.085 -0.05" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/wheel_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.15 -0.085 -0.05" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/wheel_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="wheel_2">
  <inertial>
    <origin xyz="-0.019047494333213844 1.0130785099704553e-15 -2.7755575615628914e-17" rpy="0 0 0"/>
    <mass value="2.3329933490707657"/>
    <inertia ixx="0.002974" iyy="0.001772" izz="0.001772" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.15 -0.085 -0.05" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/wheel_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.15 -0.085 -0.05" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/wheel_2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="caster_wheel_1">
  <inertial>
    <origin xyz="-1.7763568394002505e-17 0.0 8.673617379884035e-18" rpy="0 0 0"/>
    <mass value="0.032882003107573166"/>
    <inertia ixx="1e-06" iyy="1e-06" izz="1e-06" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.0 0.11 -0.01" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/caster_wheel_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.0 0.11 -0.01" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/caster_wheel_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="nozzle_stand_1">
  <inertial>
    <origin xyz="1.6002695689499647e-06 -1.4619294012863104e-07 0.02513039158895812" rpy="0 0 0"/>
    <mass value="0.5512958900740178"/>
    <inertia ixx="0.000258" iyy="0.000397" izz="0.000308" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="7.3e-05 0.112028 -0.105" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/nozzle_stand_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="7.3e-05 0.112028 -0.105" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/nozzle_stand_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="nozzle_1">
  <inertial>
    <origin xyz="-0.015000366311346575 -0.00039855919271747364 2.7755575615628914e-17" rpy="0 0 0"/>
    <mass value="0.43139411946496603"/>
    <inertia ixx="0.000128" iyy="9.4e-05" izz="9.8e-05" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.014927 0.112028 -0.145" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/nozzle_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.014927 0.112028 -0.145" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://final_assembly_description/meshes/nozzle_1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="Revolute 1" type="continuous">
  <origin xyz="0.15 0.085 0.05" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="wheel_1"/>
  <axis xyz="1.0 0.0 0.0"/>
</joint>

<joint name="Revolute 2" type="continuous">
  <origin xyz="-0.15 0.085 0.05" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="wheel_2"/>
  <axis xyz="1.0 0.0 0.0"/>
</joint>

<joint name="Ball 3" type="fixed">
  <origin xyz="0.0 -0.11 0.01" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="caster_wheel_1"/>
</joint>

<joint name="Revolute 4" type="fixed">
  <origin xyz="-7.3e-05 -0.112028 0.105" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="nozzle_stand_1"/>
</joint>

<joint name="Revolute 5" type="continuous">
  <origin xyz="0.015 0.0 0.04" rpy="0 0 0"/>
  <parent link="nozzle_stand_1"/>
  <child link="nozzle_1"/>
  <axis xyz="-1.0 0.0 0.0"/>
</joint>

<ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>gazebo_ros2_control/GazeboSystem</plugin>
  </hardware>
  <joint name="Revolute 5">
    <command_interface name="velocity">
      <param name="min">-1.0</param>
      <param name="max">1.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

<!-- LiDAR Link -->
<link name="lidar_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.1"/>
    <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" iyz="0" ixz="0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.04" length="0.04"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.04" length="0.04"/>
    </geometry>
  </collision>
</link>

<joint name="lidar_joint" type="fixed">
  <!-- Place lidar at the top of the robot, facing forward (rotated 90 deg around Z to align X with Y) -->
  <origin xyz="0 -0.03 0.25" rpy="0 0 1.5708"/> 
  <parent link="base_link"/>
  <child link="lidar_link"/>
</joint>

</robot>
